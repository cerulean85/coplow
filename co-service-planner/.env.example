# Service Planner Agent 환경변수 설정
# 이 파일을 복사해 .env 파일을 만들고 실제 값을 입력하세요:
#   cp .env.example .env

# ─────────────────────────────────────────────
# LLM API 키 (최소 하나 필수)
# ─────────────────────────────────────────────

# Anthropic (기본값 — claude-3-opus-20240229 사용)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (선택 — --provider openai 옵션 사용 시)
OPENAI_API_KEY=your-openai-api-key-here

# ─────────────────────────────────────────────
# 웹 검색 (선택)
# ─────────────────────────────────────────────

# Serper.dev API 키 (설정 시 에이전트가 웹 검색 가능)
# https://serper.dev 에서 무료 키 발급
SERPER_API_KEY=your-serper-api-key-here
