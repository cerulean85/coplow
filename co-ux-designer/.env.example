# ── API 키 ──────────────────────────────────────────────
# Anthropic Claude 모델 사용 시 필수
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI 모델 사용 시 필수
OPENAI_API_KEY=your_openai_api_key_here

# ── LLM 설정 ────────────────────────────────────────────
# 사용할 모델 (환경변수로 기본값 지정, CLI --model 인자로 런타임 변경 가능)
#
# Anthropic 모델:
#   anthropic/claude-opus-4-6       (단축명: opus, claude-opus)
#   anthropic/claude-sonnet-4-6     (단축명: sonnet, claude-sonnet)
#   anthropic/claude-haiku-4-5-20251001 (단축명: haiku)
#
# OpenAI 모델:
#   openai/gpt-4o                   (단축명: gpt-4o)
#   openai/gpt-4o-mini              (단축명: gpt-4o-mini)
#   openai/gpt-4                    (단축명: gpt-4)
#
LLM_MODEL=anthropic/claude-opus-4-6

# 생성 온도 (0.0 = 결정적, 1.0 = 창의적 / UX 설계 기본값: 0.3)
LLM_TEMPERATURE=0.3

# 최대 출력 토큰 수
LLM_MAX_TOKENS=8192
